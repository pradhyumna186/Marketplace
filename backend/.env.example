# Database Configuration
# Update with your PostgreSQL database details
DB_URL=jdbc:postgresql://localhost:5432/stoneridge_marketplace
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Email Configuration (Gmail SMTP)
# For Gmail, you need to:
# 1. Enable 2-Step Verification
# 2. Generate an App Password (not your regular password)
# 3. Use that App Password here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# JWT Configuration
# Generate a secure 256-bit secret key using: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Application URL
# Update this for production deployment
APP_BASE_URL=http://localhost:8080
